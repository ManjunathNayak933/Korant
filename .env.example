# Korant — Environment Variables
# Copy to .env.local for local development
# Add all of these to Cloudflare Pages dashboard for production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT (minimum 32 characters — generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-here

# Admin credentials
ADMIN_EMAIL=admin@korant.app
ADMIN_PASSWORD=your-secure-admin-password

# App URLs
NEXT_PUBLIC_BASE_URL=https://app.korant.in
BASE_URL=https://app.korant.in

# Google OAuth (for Search Console integration)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudflare KV (set in wrangler.toml / Cloudflare Pages dashboard)
# KV namespace binding: METRICS_CACHE

# WhatsApp Business Cloud API (Meta)
# Get from: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_WEBHOOK_VERIFY_TOKEN=korant-wa-verify
NEXT_PUBLIC_WA_VERIFY_TOKEN=korant-wa-verify
